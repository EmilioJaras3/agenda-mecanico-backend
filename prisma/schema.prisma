generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolUsuario {
  cliente
  mecanico
}

model Usuario {
  id             Int          @id @default(autoincrement())
  nombre         String
  email          String       @unique
  telefono       String
  contrasena     String
  rol            RolUsuario
  fecha_creacion DateTime     @default(now())
  activo         Boolean      @default(true)
  citas          Cita[]
}
